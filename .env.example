# Copia questo file in ".env" e riempi i due valori.

# Token di accesso alla PAGINA Facebook (NON il tuo token personale).
# Come ottenerlo: vedi README.md, sezione "2. Token Pagina".
FB_PAGE_TOKEN=incolla_qui_il_token_pagina

# Chiave API di Claude (console.anthropic.com -> API Keys).
ANTHROPIC_API_KEY=sk-ant-incolla_qui_la_chiave
